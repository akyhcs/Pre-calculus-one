<h1>Number Systems</h1>
<p class="subtitle">ℕ ⊂ ℤ ⊂ ℚ ⊂ ℝ ⊂ ℂ</p>

<div class="nest-wrap">

  <!-- ℂ -->
  <div class="box c-box">
    <div class="box-label">
      <span class="symbol">ℂ</span>
      <span class="name">Complex Numbers</span>
      <span class="tag">outermost</span>
    </div>
    <div class="examples">
      <span class="ex">3 + 2i</span>
      <span class="ex">−½ + √7·i</span>
      <span class="ex">5i</span>
      <span class="ex">−i</span>
    </div>
    <div class="motivation">Needed because x² = −1 has no real solution → introduced <em>i</em> = √−1</div>

    <!-- ℝ -->
    <div class="box r-box">
      <div class="box-label">
        <span class="symbol">ℝ</span>
        <span class="name">Real Numbers</span>
        <span class="tag">includes irrationals</span>
      </div>
      <div class="examples">
        <span class="ex">√2</span>
        <span class="ex">π</span>
        <span class="ex">e</span>
        <span class="ex">√17</span>
        <span class="ex">−√5</span>
      </div>
      <div class="motivation">Needed because x² = 2 has no rational solution</div>

      <!-- ℚ -->
      <div class="box q-box">
        <div class="box-label">
          <span class="symbol">ℚ</span>
          <span class="name">Rational Numbers</span>
          <span class="tag">p/q form</span>
        </div>
        <div class="examples">
          <span class="ex">½</span>
          <span class="ex">−⅔</span>
          <span class="ex">¾</span>
          <span class="ex">5/4</span>
          <span class="ex">0.333…</span>
        </div>
        <div class="motivation">Needed because 2x = 1 has no integer solution</div>

        <!-- ℤ -->
        <div class="box z-box">
          <div class="box-label">
            <span class="symbol">ℤ</span>
            <span class="name">Integers</span>
            <span class="tag">+ negatives</span>
          </div>
          <div class="examples">
            <span class="ex">…−3</span>
            <span class="ex">−2</span>
            <span class="ex">−1</span>
            <span class="ex">0</span>
            <span class="ex">1</span>
            <span class="ex">2…</span>
          </div>
          <div class="motivation">Needed because x + 2 = 1 has no natural-number solution</div>

          <!-- ℕ -->
          <div class="box n-box">
            <div class="box-label">
              <span class="symbol">ℕ</span>
              <span class="name">Natural Numbers</span>
              <span class="tag">innermost</span>
            </div>
            <div class="examples">
              <span class="ex">0</span>
              <span class="ex">1</span>
              <span class="ex">2</span>
              <span class="ex">3</span>
              <span class="ex">4</span>
              <span class="ex">…</span>
            </div>
            <div class="motivation" style="margin-bottom:0">Where it all begins — counting numbers</div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<!-- chain -->
<div class="chain">
  <span class="chain-sym cn">ℕ</span>
  <span class="chain-op">⊂</span>
  <span class="chain-sym cz">ℤ</span>
  <span class="chain-op">⊂</span>
  <span class="chain-sym cq">ℚ</span>
  <span class="chain-op">⊂</span>
  <span class="chain-sym cr">ℝ</span>
  <span class="chain-op">⊂</span>
  <span class="chain-sym cc">ℂ</span>
</div>

