  }

  /* ── Nested boxes ── */
  .nest-wrap {
    position: relative;
    width: min(560px, 94vw);
  }

  .box {
    position: relative;
    border-radius: 18px;
    padding: 22px 22px 22px 22px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    cursor: default;
  }
  .box:hover { transform: scale(1.015); }

  /* label row */
  .box-label {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 14px;
  }
  .symbol {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1;
  }
  .name {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.75;
  }
  .tag {
    margin-left: auto;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    padding: 3px 8px;
    border-radius: 99px;
    opacity: 0.7;
  }

  /* examples strip */
  .examples {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }
  .ex {
    font-size: 0.7rem;
    padding: 3px 10px;
    border-radius: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
  }

  /* motivation bar */
  .motivation {
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    opacity: 0.55;
    border-left: 2px solid currentColor;
    padding-left: 10px;
    margin-bottom: 14px;
  }

  /* ── Individual set colors ── */

  /* ℂ — outermost */
  .c-box {
    background: linear-gradient(145deg, #1a0a2e 0%, #120820 100%);
    border: 2px solid #7c3aed55;
    box-shadow: 0 0 40px #7c3aed18, inset 0 0 30px #7c3aed08;
  }
  .c-box .symbol { color: #a78bfa; }
  .c-box .tag { background: #7c3aed30; color: #a78bfa; border: 1px solid #7c3aed55; }
  .c-box .motivation { color: #a78bfa; }

  /* ℝ */
  .r-box {
    background: linear-gradient(145deg, #0f1f12 0%, #0a1a0d 100%);
    border: 2px solid #16a34a55;
    box-shadow: 0 0 30px #16a34a12;
  }
  .r-box .symbol { color: #4ade80; }
  .r-box .tag { background: #16a34a30; color: #4ade80; border: 1px solid #16a34a55; }
  .r-box .motivation { color: #4ade80; }

  /* ℚ */
